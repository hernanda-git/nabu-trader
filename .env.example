# Telegram API (from my.telegram.org)
TG_API_ID=YOUR_API_ID
TG_API_HASH=YOUR_API_HASH

# Channel to monitor
CHANNEL_USERNAME=Nabu Trader

# Telethon StringSession (headless login for the listener on Fly.io).
# Generate once with `python scripts/gen_session.py`, then set as a Fly
# secret: flyctl secrets set SESSION_STRING="..." --app nabu-trader
# If empty, the bot falls back to a file-based session at /data/sessions/
SESSION_STRING=

# Notification target (Hermes bot chat)
NOTIFY_CHAT_ID=YOUR_CHAT_ID

# Telegram Bot Token (for sending notifications via bot)
# Get from @BotFather, or use your own bot token
TELEGRAM_BOT_TOKEN=

# Optional: Binance API (Phase 2)
BINANCE_API_KEY=
BINANCE_API_SECRET=
