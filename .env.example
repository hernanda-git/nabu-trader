# ─── Telegram (Required) ───
TG_API_ID=your_api_id_from_my_telegram_org
TG_API_HASH=your_api_hash_from_my_telegram_org
CHANNEL_USERNAME=your_signal_channel_username
NOTIFY_CHAT_ID=your_telegram_chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ─── LLM (Required) ───
# Any OpenAI-compatible endpoint
OPENCODE_GO_API_KEY=your_llm_api_key

# ─── Binance (Optional - skip for paper trading) ───
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# ─── API Bridge (Optional) ───
API_KEY=your_api_bridge_key

# ─── Webhook (Optional) ───
# WEBHOOK_URL=https://your-webhook.url
# WEBHOOK_HMAC_SECRET=your-hmac-secret
